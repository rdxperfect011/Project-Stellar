{
  "builds": [
    {
      "src": "run.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "/static/$1"
    },
    {
      "src": "/api/(.*)",
      "headers": {
        "Cache-Control": "s-maxage=60, stale-while-revalidate=300"
      },
      "dest": "run.py"
    },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=3600, must-revalidate"
      },
      "dest": "run.py"
    }
  ]
}
